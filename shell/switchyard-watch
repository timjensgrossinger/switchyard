#!/usr/bin/env python3
"""Live status viewer for Switchyard subtasks.

Run this in a separate terminal tab to see real-time subtask execution
while prompts are being processed in your main terminal.

Usage:
    switchyard-watch          # pretty table view, refreshes every 1s
    switchyard-watch --json   # raw JSON, refreshes every 1s
    switchyard-watch --once   # print once and exit
"""

import json
import os
import sys
import time

STATUS_FILE = "/tmp/switchyard-status.json"

# ANSI colors
RESET  = "\033[0m"
BOLD   = "\033[1m"
DIM    = "\033[2m"
GREEN  = "\033[32m"
YELLOW = "\033[33m"
RED    = "\033[31m"
CYAN   = "\033[36m"
BLUE   = "\033[34m"

STATUS_COLORS = {
    "running": YELLOW,
    "done": GREEN,
    "failed": RED,
}


def read_status():
    try:
        with open(STATUS_FILE) as f:
            return json.load(f)
    except (FileNotFoundError, json.JSONDecodeError):
        return None


def render_task(task, width=80):
    status = task.get("status", "?")
    color = STATUS_COLORS.get(status, DIM)
    icon = {"running": "⏳", "done": "✅", "failed": "❌"}.get(status, "❓")

    tid = task.get("task_id", "?")[:10]
    tier = task.get("tier", "?")
    model = task.get("model") or "resolving..."
    provider = task.get("provider", "")
    target = task.get("target_file", "")
    if target:
        target = os.path.basename(target)
    elapsed = task.get("elapsed")
    elapsed_str = f"{elapsed:.1f}s" if elapsed is not None else ""
    wave = task.get("wave_id", "")

    line = f"  {icon} {color}{status:<8}{RESET} "
    line += f"{DIM}[{tier}]{RESET} "
    if model:
        line += f"{CYAN}{model}{RESET} "
    if provider:
        line += f"{DIM}via {provider}{RESET} "
    if target:
        line += f"→ {BOLD}{target}{RESET} "
    if elapsed_str:
        line += f"{DIM}({elapsed_str}){RESET}"
    return line


def render(data, raw_json=False):
    if raw_json:
        print(json.dumps(data, indent=2))
        return

    updated = data.get("updated_at", "?")
    active = data.get("active", [])
    recent = data.get("recent", [])

    print(f"{BOLD}Switchyard Status{RESET}  {DIM}updated {updated}{RESET}")
    print(f"{DIM}{'─' * 70}{RESET}")

    if active:
        print(f"\n{BOLD}{YELLOW}⚡ Active ({len(active)}){RESET}")
        # Group by wave
        waves = {}
        for t in active:
            w = t.get("wave_id", "default")
            waves.setdefault(w, []).append(t)
        for wave_name, tasks in waves.items():
            if len(tasks) > 1:
                print(f"  {BLUE}┌ wave: {wave_name} ({len(tasks)} parallel){RESET}")
            for t in tasks:
                print(render_task(t))
            if len(tasks) > 1:
                print(f"  {BLUE}└{RESET}")
    else:
        print(f"\n{DIM}  No active subtasks{RESET}")

    if recent:
        print(f"\n{BOLD}📋 Recent ({len(recent)}){RESET}")
        for t in recent:
            print(render_task(t))

    # Provider health footer
    provider_health = data.get("provider_health", [])
    recent_failures = data.get("recent_failures", [])
    if provider_health or recent_failures:
        print(f"\n{BOLD}Providers{RESET}")
        state_icons = {
            "HEALTHY":     f"{GREEN}●{RESET}",
            "DEGRADED":    f"{YELLOW}~{RESET}",
            "QUARANTINED": f"{RED}●{RESET}",
            "PROBING":     f"{CYAN}◐{RESET}",
        }
        for ph in provider_health:
            state = ph.get("state", "HEALTHY")
            icon = state_icons.get(state, "?")
            name = ph.get("provider_id", "?")
            failures = ph.get("consecutive_failures", 0)
            label = f"{state.lower()}"
            extra = ""
            until = ph.get("quarantine_until_ts")
            if until:
                import time as _time
                extra = f"  until {_time.strftime('%H:%M:%S', _time.localtime(until))}"
            cat = ph.get("last_failure_category", "")
            if cat:
                extra += f"  ({cat})"
            print(f"  {icon} {name:<20} {DIM}{label}{RESET}{DIM}{extra}  {failures} failures{RESET}")

        if recent_failures:
            print(f"\n{BOLD}Recent Failures{RESET}")
            for rf in recent_failures[:5]:
                ts = rf.get("ts", 0)
                ts_str = ""
                if ts:
                    import time as _time
                    ts_str = _time.strftime("%H:%M:%S", _time.localtime(ts)) + "  "
                provider = rf.get("provider_id", "?")
                cat = rf.get("category", rf.get("error_category", "?"))
                stderr = rf.get("stderr_snippet", "")
                snip = f'  "{stderr[:60]}"' if stderr else ""
                print(f"  {DIM}{ts_str}{RESET}{YELLOW}{provider}{RESET}  {DIM}{cat}{snip}{RESET}")

    print(f"\n{DIM}File: {STATUS_FILE}  |  Ctrl+C to exit{RESET}")


def main():
    raw_json = "--json" in sys.argv
    once = "--once" in sys.argv

    while True:
        os.system("clear" if os.name != "nt" else "cls")
        data = read_status()
        if data:
            render(data, raw_json=raw_json)
        else:
            print(f"{DIM}Waiting for Switchyard status...{RESET}")
            print(f"{DIM}(Status file: {STATUS_FILE}){RESET}")
            print(f"{DIM}Start a build in your main terminal to see subtasks here.{RESET}")

        if once:
            break
        try:
            time.sleep(1)
        except KeyboardInterrupt:
            print(f"\n{DIM}Stopped.{RESET}")
            break


if __name__ == "__main__":
    main()
